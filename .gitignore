# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
.aws-sam/
lambda/
.claude/worktrees/
.next-old/

# Supabase CLI local state
supabase/.temp/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
.env*.local

# Phase 44 audit script runtime artifacts (read-only reports from
# scripts/audit-xero-pl-lines-duplicates.ts — regenerated on every run)
scripts/audit-xero-pl-lines-duplicates-report-*.md

# Phase 44.1 canary snapshot files (runtime artifacts containing business data;
# emitted by scripts/canary-forecast-save.ts — never committed)
.planning/phases/44.1-atomic-save-hardening-and-staged-rollout/canary-snapshot-*.json

# macOS Finder duplicates ("file 2.md", "file 3.ts", etc.) — generated when
# someone duplicates a file in Finder instead of copy/paste. Keep these out
# of the working tree so they never accumulate again.
* [0-9].*
* [0-9][0-9].*

# Phase 68 — Armstrong rollback snapshots (large, regenerable, contain tenant PII)
scripts/snapshots/*.json
