# WisdomBI Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# SUPABASE - Required
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# New API keys (preferred) — provision in Supabase Dashboard -> Settings -> API Keys.
# Publishable: browser-safe, respects RLS. Secret: server-only, bypasses RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Legacy JWT keys — FALLBACK ONLY. Valid until end of 2026. The app reads the
# new keys above first and falls back to these (see src/lib/supabase/keys.ts).
# Keep them set during the transition; remove once the new keys are verified in
# every environment. SUPABASE_SERVICE_KEY and SUPABASE_SERVICE_ROLE_KEY are both
# recognised — the codebase historically used both names.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL=https://wisdombi.ai

# =============================================================================
# EMAIL - Resend
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxx

# =============================================================================
# REPORT VIEW LINKS - Phase 35
# =============================================================================
# HMAC-SHA256 signing secret for public report view tokens (/reports/view/[token]).
# Generate once: openssl rand -hex 32
# WARNING: Rotating this value invalidates every existing client report link.
REPORT_LINK_SECRET=your-32-byte-hex-secret

# =============================================================================
# AI - OpenAI (Optional - for AI features)
# =============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# =============================================================================
# XERO INTEGRATION (Optional)
# =============================================================================
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
NEXT_PUBLIC_XERO_API_URL=https://api.xero.com

# =============================================================================
# DEVELOPMENT
# =============================================================================
# NODE_ENV=development

# =============================================================================
# CRON AUTH — Phase 46 SEC-02
# =============================================================================
# Required by GET /api/Xero/sync-all and GET /api/Xero/refresh-tokens. The
# routes now fail closed: if CRON_SECRET is unset OR the request's Bearer
# does not match, the response is 401 — including in dev/preview. Any
# string works locally; Vercel-Cron supplies the prod value.
CRON_SECRET=local-dev-secret

# CFO Report Email Sender (Phase 35)
# Single verified Resend sender. Reply-To still uses the coach's own email.
REPORT_FROM_EMAIL=cfo@yourdomain.com
REPORT_FROM_NAME=Your Brand CFO

# ─── Phase 44.1 — Forecast Read Invariants ──────────────────────────────────
# When unset or 'false' (default), ForecastReadService logs invariant violations
# to Sentry with tag `invariant_violation_logged` and returns the row anyway.
# When 'true', violations throw a 500. Soak window: 24-48h of clean Sentry data
# (zero `invariant_violation_logged` events) before flipping to true. See
# .planning/phases/44.1-atomic-save-hardening-and-staged-rollout/44.1-CONTEXT.md
# (D-44.1-08 through D-44.1-12).
FORECAST_INVARIANTS_STRICT=false
