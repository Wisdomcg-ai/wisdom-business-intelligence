# WisdomBI Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# SUPABASE - Required
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# New API keys (preferred) — provision in Supabase Dashboard -> Settings -> API Keys.
# Publishable: browser-safe, respects RLS. Secret: server-only, bypasses RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Legacy JWT keys — FALLBACK ONLY. Valid until end of 2026. The app reads the
# new keys above first and falls back to these (see src/lib/supabase/keys.ts).
# Keep them set during the transition; remove once the new keys are verified in
# every environment. SUPABASE_SERVICE_KEY and SUPABASE_SERVICE_ROLE_KEY are both
# recognised — the codebase historically used both names.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL=https://wisdombi.ai

# =============================================================================
# EMAIL - Resend
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxx

# =============================================================================
# REPORT VIEW LINKS - Phase 35
# =============================================================================
# HMAC-SHA256 signing secret for public report view tokens (/reports/view/[token]).
# Generate once: openssl rand -hex 32
# WARNING: Rotating this value invalidates every existing client report link.
REPORT_LINK_SECRET=your-32-byte-hex-secret

# =============================================================================
# AI - OpenAI (Optional - for AI features)
# =============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# =============================================================================
# XERO INTEGRATION (Optional)
# =============================================================================
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
NEXT_PUBLIC_XERO_API_URL=https://api.xero.com

# =============================================================================
# DEVELOPMENT
# =============================================================================
# NODE_ENV=development

# =============================================================================
# CRON AUTH — Phase 46 SEC-02
# =============================================================================
# Required by GET /api/Xero/sync-all and GET /api/Xero/refresh-tokens. The
# routes now fail closed: if CRON_SECRET is unset OR the request's Bearer
# does not match, the response is 401 — including in dev/preview. Any
# string works locally; Vercel-Cron supplies the prod value.
CRON_SECRET=local-dev-secret

# CFO Report Email Sender (Phase 35)
# Single verified Resend sender. Reply-To still uses the coach's own email.
REPORT_FROM_EMAIL=cfo@yourdomain.com
REPORT_FROM_NAME=Your Brand CFO

# ─── Phase 44.1 — Forecast Read Invariants ──────────────────────────────────
# When unset or 'false' (default), ForecastReadService logs invariant violations
# to Sentry with tag `invariant_violation_logged` and returns the row anyway.
# When 'true', violations throw a 500. Soak window: 24-48h of clean Sentry data
# (zero `invariant_violation_logged` events) before flipping to true. See
# .planning/phases/44.1-atomic-save-hardening-and-staged-rollout/44.1-CONTEXT.md
# (D-44.1-08 through D-44.1-12).
FORECAST_INVARIANTS_STRICT=false

# =============================================================================
# BRANDING (R7) — all optional; default to WisdomBI in src/lib/config/brand.ts.
# A FORK (e.g. inLIFE Pulse) MUST set these, or it silently shows WisdomBI.
# =============================================================================
# NEXT_PUBLIC_APP_NAME=WisdomBI
# NEXT_PUBLIC_APP_TITLE=WisdomBi - Business Intelligence
# NEXT_PUBLIC_APP_DESCRIPTION=
# NEXT_PUBLIC_BRAND_LOGO_URL=
# NEXT_PUBLIC_FAVICON_PATH=/favicon.png
# NEXT_PUBLIC_SUPPORT_EMAIL=support@wisdombi.ai
# NEXT_PUBLIC_LEGAL_ENTITY=
# NEXT_PUBLIC_LEGAL_ABN=11 331 804 705
# NEXT_PUBLIC_LEGAL_TRADING_AS=Wisdom Coaching
# NEXT_PUBLIC_DEFAULT_APP_URL=https://wisdombi.ai

# =============================================================================
# ENCRYPTION & SECRETS — generate fresh per environment: openssl rand -hex 32
# =============================================================================
# Encrypts stored Xero OAuth tokens. NEVER rotate on a live env with existing
# tokens (they become undecryptable). (R18 will unify these names.)
ENCRYPTION_KEY=your-32-byte-hex-secret
APP_SECRET_KEY=your-32-byte-hex-secret
# Signs the Xero OAuth `state` parameter (CSRF protection on the OAuth flow).
OAUTH_STATE_SECRET=your-32-byte-hex-secret

# =============================================================================
# AI - Anthropic (AI CFO assistant)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# =============================================================================
# RATE LIMITING - Upstash Redis (R11). Provision via the Vercel Marketplace; it
# injects KV_REST_API_* automatically. The limiter reads either KV_ or UPSTASH_
# names; without them it falls back to a per-instance in-memory limiter.
# =============================================================================
# KV_REST_API_URL=https://your-db.upstash.io
# KV_REST_API_TOKEN=xxxxxxxx
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# =============================================================================
# FX RATES - OpenExchangeRates (consolidation / multi-currency)
# =============================================================================
OPENEXCHANGERATES_APP_ID=your-oxr-app-id

# =============================================================================
# SENTRY (server fails loud in production if unset — see sentry.server.config.ts)
# =============================================================================
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# =============================================================================
# EMAIL SENDER (Resend) — verified sending identity
# =============================================================================
# SENDER_EMAIL=noreply@mail.wisdombi.ai
# SENDER_FROM=WisdomBI <noreply@mail.wisdombi.ai>

# =============================================================================
# ADMIN / DEMO
# =============================================================================
# ADMIN_EMAIL=admin@yourdomain.com
# Demo client login (super-admin demo tool). Set a STRONG value — there is no
# secure hardcoded default (R36/MNT-N9).
# DEMO_CLIENT_EMAIL=demo@yourdomain.com
# DEMO_CLIENT_PASSWORD=set-a-strong-password

# =============================================================================
# FEATURE FLAGS (defaults are safe)
# =============================================================================
# Zod input validation: empty = observe-mode (log only). Comma-list of routeIds
# or '*' to ENFORCE (return 400). Keep EMPTY until prod bake proves no false rejects.
# ZOD_ENFORCE_ROUTES=
# Section-permission gate: unset = LOG_ONLY; 'true' = enforce.
# SECTION_PERMISSION_ENFORCE=
# Forecast FX engine kill-switch (consolidation): 'true' disables FX-via-engine.
# FORECAST_FX_VIA_ENGINE_DISABLE=
